rules_version = '2';

// Firebase Storage Security Rules for NWR Maintenance Portal
// Resources library - organized by transmitter type

service firebase.storage {
  match /b/{bucket}/o {

    // Resources folder structure: /resources/{category}/{filename}
    // Categories: armstrong, crown, nautel
    match /resources/{category}/{filename} {
      // Allow all authenticated users to read (download) resources
      allow read: if request.auth != null;

      // Only authenticated users can write (upload/delete) resources
      // In practice, the application layer restricts this to admins only
      allow write: if request.auth != null;
    }

    // Deny all other access by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
