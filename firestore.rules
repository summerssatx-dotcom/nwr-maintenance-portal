rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================================
    // FIREBASE FIRESTORE SECURITY RULES
    // NWR Maintenance Portal v2
    // ============================================================================
    //
    // IMPORTANT: Deploy these rules to Firebase Console
    // Current State: Google Sign-In with @noaa.gov domain restriction
    // Role-Based Access Control: admin, editor, viewer
    // ============================================================================

    // Helper function: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function: Check if user owns the document (by techId/userId)
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function: Get user role from user_roles collection
    function getUserRole() {
      return get(/databases/$(database)/documents/artifacts/$(appId)/public/data/user_roles/$(request.auth.uid)).data.role;
    }

    // Helper function: Check if user can edit (admin or editor)
    function canEdit() {
      let role = getUserRole();
      return role == 'admin' || role == 'editor';
    }

    // Helper function: Check if user is admin
    function isAdmin() {
      return getUserRole() == 'admin';
    }

    // Helper function: Validate inspection data structure
    function isValidInspection() {
      let data = request.resource.data;
      return data.keys().hasAll(['siteId', 'date', 'timestamp', 'techId']) &&
             data.siteId is string &&
             data.date is string &&
             data.timestamp is string &&
             data.techId is string;
    }

    // Root artifacts collection
    match /artifacts/{appId} {
      // Public data document
      match /public/data {
        // Allow read access to the document itself
        allow read: if isAuthenticated();

        // Inspections subcollection
        match /inspections/{inspectionId} {
          // Allow read access to authenticated users
          allow read: if isAuthenticated();

          // Allow create if authenticated and data is valid
          allow create: if isAuthenticated() && isValidInspection();

          // Allow update/delete only if user is the owner
          allow update, delete: if isAuthenticated() &&
                                   isOwner(resource.data.techId);
        }

        // Maintenance logs subcollection
        match /logs/{logId} {
          // Allow read access to authenticated users
          allow read: if isAuthenticated();

          // Allow create if authenticated
          allow create: if isAuthenticated();

          // Allow update/delete only if user is the owner
          allow update, delete: if isAuthenticated() &&
                                   isOwner(resource.data.userId);
        }

        // User roles subcollection (for role-based access control)
        match /user_roles/{userId} {
          // Anyone authenticated can read their own role
          allow read: if isAuthenticated();

          // Only admins can create/update/delete user roles
          allow create, update, delete: if isAdmin();
        }

        // Calendar events subcollection (shared team calendar)
        match /calendar_events/{eventId} {
          // Allow read access to all authenticated users
          allow read: if isAuthenticated();

          // Allow create/update/delete only for admins and editors
          allow create, update, delete: if isAuthenticated() && canEdit();
        }

        // Site statuses subcollection (shared team data)
        match /site_statuses/{siteId} {
          // Allow read access to all authenticated users
          allow read: if isAuthenticated();

          // Allow create/update/delete only for admins and editors
          allow create, update, delete: if isAuthenticated() && canEdit();
        }

        // Maintenance log subcollection (shared team log)
        match /maintenance_log/{logId} {
          // Allow read access to all authenticated users
          allow read: if isAuthenticated();

          // Allow create/update/delete only for admins and editors
          allow create, update, delete: if isAuthenticated() && canEdit();
        }
      }
    }

    // ============================================================================
    // IMPLEMENTED SECURITY FEATURES:
    // ============================================================================
    // ✅ 1. Google Sign-In with @noaa.gov domain restriction
    // ✅ 2. Role-based access control (admin, editor, viewer)
    // ✅ 3. User roles managed in Firebase Console
    //
    // FUTURE ENHANCEMENTS:
    // ============================================================================
    // 1. Add field-level validation for all data types
    // 2. Implement rate limiting to prevent abuse
    // 3. Add audit logging for all write operations
    // ============================================================================

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
